{
  "realm": "mercury",
  "enabled": true,

  "clientScopes": [
    {
      "name": "catalog:read",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "orders:write",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "payments:write",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    }
  ],

  "clients": [
    {
      "clientId": "mercury-load-client",
      "enabled": true,

      "publicClient": false,
      "secret": "load-secret",

      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,

      "defaultClientScopes": [
        "profile",
        "email",
        "roles",
        "web-origins",
        "catalog:read",
        "orders:write",
        "payments:write"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access"
      ]
    }
  ]
}